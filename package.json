{
  "name": "hololed-cloud",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm --workspace apps/api run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:admin": "npm --workspace apps/admin run dev",
    "dev:gateway": "npm --workspace apps/gateway run dev",
    "dev:worker": "npm --workspace apps/worker run dev",
    "dev:docs": "npm --workspace apps/docs run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test && npm run test:ci-configuration",
    "test:ci-configuration": "node --test tests/integration/*.test.mjs",
    "db:generate": "npm --workspace apps/api run db:generate",
    "db:migrate": "npm --workspace apps/api run db:migrate",
    "db:deploy": "npm --workspace apps/api run db:deploy"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "npm@10.8.0",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.6.0",
    "eslint-config-next": "^16.2.10",
    "turbo": "^2.10.4"
  }
}