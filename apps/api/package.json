{
  "name": "@hololed/api",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "lint": "tsc -p tsconfig.lint.json --noEmit",
    "test": "node --test",
    "db:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema ../../prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema ../../prisma/schema.prisma"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1093.0",
    "@aws-sdk/s3-request-presigner": "^3.1093.0",
    "@fastify/cors": "^11.3.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@hololed/shared": "1.0.0",
    "@prisma/client": "^7.9.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.4.2",
    "fastify": "^5.10.0",
    "fastify-type-provider-zod": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.15.2",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.0",
    "prisma": "^7.8.0",
    "tsx": "^4.20.3",
    "typescript": "^6.0.3"
  }
}